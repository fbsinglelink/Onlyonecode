modules = ["web", "nodejs-20", "bash", "python-3.11"]

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python3 -m http.server 5000"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[deployment]
run = ["sh", "-c", "chmod +x clone_and_run.sh && ./clone_and_run.sh"]
deploymentTarget = "static"
publicDir = "."

[[ports]]
localPort = 5000
externalPort = 80

[agent]
expertMode = true
